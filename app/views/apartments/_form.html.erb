<div id="property-form">
  <%= form_with model: property, builder: BootstrapFormBuilder, html: { class: "" } do |f| %>
    <div class="w-25 row g-3">
      <div class="col-12">
        <%= f.label :address %>
        <%= f.text_field :address %>
        <div class="valid-feedback">
          Looks good!
        </div>
      </div>
      <div class="col-md-9">
        <%= f.label :city %>
        <%= f.text_field :city %>
      </div>
      <div class="col-md-3">
        <%= f.label :zip %>
        <%= f.text_field :zip %>
      </div>
      <div class="col-md-6">
        <%= f.label :size %>
        <%= f.text_field :size %>
      </div>
      <div class="col-md-6">
        <%= f.label :price %>
        <%= f.text_field :price %>
      </div>
      <div class="d-flex justify-content-between">
        <div class="col-md-2">
          <%= f.label :bathroom_count, "Bathrooms" %>
          <%= f.text_field :bathroom_count %>
        </div>
        <div class="col-md-2">
          <%= f.label :bedroom_count, "Bedrooms" %>
          <%= f.text_field :bedroom_count %>
        </div>
        <div class="col-md-2">
          <%= f.label :floor_level, "Floor" %>
          <%= f.text_field :floor_level %>
        </div>
      </div>
      <div class="col-12">
        <%= f.submit "Add Apartment" %>
      </div>
    </div>
  <% end %>
</div>